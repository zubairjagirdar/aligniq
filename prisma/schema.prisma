generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  name              String?
  role              Role                 @default(EMPLOYEE)
  goals             Goal[]               @relation("ownerGoals")
  sharedGoalOwners  SharedGoalOwner[]
  checkins          Checkin[]
  auditLogs         AuditLog[]
  activityLogs      ActivityLog[]
  notifications     Notification[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

model Goal {
  id             String     @id @default(cuid())
  ownerId        String
  owner          User       @relation(fields: [ownerId], references: [id], name: "ownerGoals")
  title          String
  description    String?
  targetValue    Float
  unit           String
  weight         Int
  type           GoalType
  status         GoalStatus @default(NOT_STARTED)
  startDate      DateTime?
  endDate        DateTime?
  sharedGoalId   String?
  sharedGoal     SharedGoal? @relation(fields: [sharedGoalId], references: [id])
  checkins       Checkin[]
  escalations    Escalation[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum GoalType {
  MIN
  MAX
  ZERO
  TIMELINE
}

enum GoalStatus {
  NOT_STARTED
  ON_TRACK
  COMPLETED
}

model SharedGoal {
  id           String  @id @default(cuid())
  title        String
  description  String?
  targetValue  Float
  unit         String
  owners       SharedGoalOwner[]
  goals        Goal[]
  createdAt    DateTime @default(now())
}

model SharedGoalOwner {
  id         String @id @default(cuid())
  sharedId   String
  userId     String
  shared     SharedGoal @relation(fields: [sharedId], references: [id])
  user       User @relation(fields: [userId], references: [id])
  weight     Int
}

model Checkin {
  id         String   @id @default(cuid())
  goalId     String
  goal       Goal     @relation(fields: [goalId], references: [id])
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  progress   Float
  notes      String?
  createdAt  DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String
  actor       User     @relation(fields: [actorId], references: [id])
  entityType  String
  entityId    String
  field       String
  oldValue    String?
  newValue    String?
  timestamp   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  payload   Json
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Escalation {
  id           String   @id @default(cuid())
  goalId       String
  goal         Goal     @relation(fields: [goalId], references: [id])
  level        Int
  escalatedAt  DateTime @default(now())
  resolved     Boolean  @default(false)
}

model AIInsight {
  id          String   @id @default(cuid())
  goalId      String
  type        String
  score       Float
  payload     Json
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  meta      Json?
  createdAt DateTime @default(now())
}
